<?xml version="1.0" encoding="utf-8"?>
<!--
  Unitree Go2W URDF — kinematic model used by dg_kilo for forward kinematics.
  Sourced from unitreerobotics/unitree_ros @ robots/go2w_description (BSD-3-Clause).
  See ORIGIN.md for upstream commit SHA and attribution.

  Link naming follows Unitree convention:
    base → {FL,FR,RL,RR}_hip → {FL,FR,RL,RR}_thigh → {FL,FR,RL,RR}_calf → {FL,FR,RL,RR}_foot

  Motor indices in LowState.motor_state[]:
    0  FL_hip    1  FL_thigh    2  FL_calf
    3  FR_hip    4  FR_thigh    5  FR_calf
    6  RL_hip    7  RL_thigh    8  RL_calf
    9  RR_hip   10  RR_thigh   11  RR_calf
   12  FL_wheel  13 FR_wheel   14  RL_wheel  15 RR_wheel

  Wheel radius: 0.0513 m (from go2w_description mesh geometry).
-->
<robot name="go2w">

  <!-- ===================== BASE LINK ===================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <mass value="5.204"/>
      <inertia ixx="0.0168" ixy="0.0" ixz="0.0" iyy="0.0565" iyz="0.0" izz="0.0647"/>
    </inertial>
  </link>

  <!-- ===================== FRONT LEFT ===================== -->
  <link name="FL_hip">
    <inertial>
      <origin xyz="-0.022191 0.015144 -0.000015" rpy="0 0 0"/>
      <mass value="0.678"/>
      <inertia ixx="0.000469" ixy="3.1e-05" ixz="-1e-06" iyy="0.000807" iyz="-1.6e-05" izz="0.000620"/>
    </inertial>
  </link>
  <joint name="FL_hip_joint" type="revolute">
    <parent link="base_link"/>
    <child link="FL_hip"/>
    <origin xyz="0.1934 0.0465 0.0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.863" upper="0.863" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="FL_thigh">
    <inertial>
      <origin xyz="-0.005607 0.003877 -0.048199" rpy="0 0 0"/>
      <mass value="1.152"/>
      <inertia ixx="0.005666" ixy="2.2e-05" ixz="-0.000141" iyy="0.005490" iyz="-5.6e-05" izz="0.000850"/>
    </inertial>
  </link>
  <joint name="FL_thigh_joint" type="revolute">
    <parent link="FL_hip"/>
    <child link="FL_thigh"/>
    <origin xyz="0.0 0.0955 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="23.7" velocity="30.1"/>
  </joint>

  <link name="FL_calf">
    <inertial>
      <origin xyz="0.002781 0.0 -0.142518" rpy="0 0 0"/>
      <mass value="0.241"/>
      <inertia ixx="0.001669" ixy="0.0" ixz="5.8e-05" iyy="0.001598" iyz="0.0" izz="6.5e-05"/>
    </inertial>
  </link>
  <joint name="FL_calf_joint" type="revolute">
    <parent link="FL_thigh"/>
    <child link="FL_calf"/>
    <origin xyz="0.0 0.0 -0.213" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.775" upper="-0.646" effort="35.55" velocity="20.06"/>
  </joint>

  <link name="FL_foot">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <mass value="0.165"/>
      <inertia ixx="5.0e-05" ixy="0.0" ixz="0.0" iyy="5.0e-05" iyz="0.0" izz="5.0e-05"/>
    </inertial>
  </link>
  <joint name="FL_foot_joint" type="continuous">
    <parent link="FL_calf"/>
    <child link="FL_foot"/>
    <origin xyz="0.0 0.0 -0.213" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

