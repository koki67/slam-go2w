  <material name="white"><color rgba="0.9 0.9 0.86 1"/></material>

  <link name="base_link">
    <visual><geometry><mesh filename="package://wheel_legged_odometry/urdf/go2w/assets/base_0.obj"/></geometry><material name="black"/></visual>
